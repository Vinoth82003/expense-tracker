generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  email        String     @unique
  avatar       String?
  authProvider String?
  monthlyLimit Float?
  expenseMode  String?    // "limit" or "no-limit"
  onboarded    Boolean    @default(false)

  twoFactorEnabled    Boolean   @default(false)
  twoFactorOTP        String?
  twoFactorOTPExpires DateTime?
  
  expenses     Expense[]
  categories   Category[]
  incomes      Income[]

  createdAt    DateTime?   @default(now())
  updatedAt    DateTime    @updatedAt
}

model Expense {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  amount        Float
  category      String   // "Needs" or "Wants"
  subcategory   String
  note          String?
  date          DateTime
  attachmentUrl String?

  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime? @default(now())
}

model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      String   // "Needs" or "Wants"
  isDefault Boolean  @default(false)

  userId    String?  @db.ObjectId // Optional because default categories might be global, or we copy them correctly. Usually better to tie even defaults to a user for simpler queries if they can't delete them.
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  amount  Float
  source  String
  note    String?
  date    DateTime

  userId  String   @db.ObjectId
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime? @default(now())
}
